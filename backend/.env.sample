# Copy this to .env and fill values
# Path to service account JSON (optional if running on GCP with default service account)
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# If not set, firebase-admin will use Application Default Credentials
# Storage bucket name (optional, admin SDK usually reads from service account)
FIREBASE_STORAGE_BUCKET=lotex-4890a.appspot.com

# Allowed origins for CORS (comma-separated). Use '*' to allow all during development.
ALLOWED_ORIGINS=http://localhost:5000,https://your-domain.com

PORT=8080
